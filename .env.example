# ---------------------------------------------------------------------------
# Duskwarden environment
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values from your Supabase project:
#   Supabase Dashboard → Project Settings → API
#
# Both values are safe to expose in a client bundle (the anon key is protected
# by Row Level Security). Never put the *service_role* key here.
#
# If these are left blank, Duskwarden automatically runs in DEMO mode, backed
# by localStorage and seeded with the bestiary — nothing touches Supabase.
# ---------------------------------------------------------------------------

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Force demo mode even when the two values above are set (useful for local UI
# work without touching your real data). Set to "true" to enable.
VITE_DEMO=
